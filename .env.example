# Copy to .env and fill in your values
SECRET_KEY=your-secret-key-here
DEBUG=True

# ── Real email (Gmail) ──────────────────────────────────────
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → create one for "Mail"
# 3. Paste below (NOT your normal Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your.email@gmail.com
FRONTEND_URL=http://localhost:8080
# Test: python manage.py check_email --to=your.email@gmail.com

# ── Real SMS (pick ONE provider) ─────────────────────────────
# Option A — Africa's Talking (recommended for Rwanda)
# Sign up: https://africastalking.com
# Sandbox: use sandbox username + API key, set SANDBOX=True
SMS_PROVIDER=africastalking
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER=JobLink
AFRICASTALKING_SANDBOX=True

# Option B — Twilio
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Test SMS: python manage.py check_sms --phone=+250781234567

# ── Production database (PostgreSQL on Railway) ──────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://default:pass@host:6379
# CORS_ALLOWED_ORIGINS=https://your-app.com
# ALLOWED_HOSTS=your-app.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.railway.app

# ── MTN MoMo (optional — escrow simulates when unset) ────────
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_ENVIRONMENT=sandbox

# ── Cloudinary (profile photos) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ══════════════════════════════════════════════════════════════
# RAILWAY — set these in Railway dashboard → Variables
# ══════════════════════════════════════════════════════════════
# DEBUG=False
# SECRET_KEY=generate-a-long-random-string
# DATABASE_URL=          (auto from PostgreSQL plugin)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# ALLOWED_HOSTS=.up.railway.app,your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# FRONTEND_URL=https://your-app.up.railway.app
# CLOUDINARY_* (same as above)
# EMAIL_* / SMS_* / FIREBASE_CREDENTIALS_JSON (paste full JSON)
# REDIS_URL=             (optional, for live chat WebSockets)
#
# After first deploy:
#   railway run python manage.py seed_demo
#   railway run python manage.py create_admin
#   curl https://your-app.up.railway.app/api/health/
#
# Flutter → production API:
#   flutter run --dart-define=API_BASE_URL=https://your-app.up.railway.app/api
#   flutter build apk --dart-define=API_BASE_URL=https://your-app.up.railway.app/api
